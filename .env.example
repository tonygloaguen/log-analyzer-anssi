# ============================================================
# .env.example — log-analyzer-anssi
# Copier vers .env et renseigner toutes les valeurs.
# NE JAMAIS committer .env dans le dépôt git.
# ============================================================

# ─── Intégrité HMAC — ANSSI NIS2 Art.21.2.h ────────────────
# Clé secrète HMAC-SHA256 pour la signature des événements.
# OBLIGATOIRE — aucune valeur par défaut.
# Générer avec : openssl rand -hex 32
HMAC_SECRET=CHANGE_ME_generate_with_openssl_rand_hex_32

# ─── Ollama / LLM local ─────────────────────────────────────
# URL du service Ollama (pas de cloud — conformité ANSSI)
OLLAMA_BASE_URL=http://ollama:11434

# Modèle ransomware analyst (ARM64 Q4_K_M recommandé)
OLLAMA_MODEL=granite3.3:8b

# ─── Détection BYOVD ────────────────────────────────────────
# Chemin du cache loldrivers.io (pré-chargé dans le Dockerfile)
LOLDRIVERS_CACHE=/app/data/loldrivers_cache.json

# URL source pour la mise à jour hebdomadaire du cache
LOLDRIVERS_URL=https://www.loldrivers.io/api/drivers.json

# Score minimal pour émettre une alerte BYOVD (0.0–1.0)
BYOVD_RISK_THRESHOLD=0.6

# ─── Collecteur réseau ──────────────────────────────────────
# Répertoire des logs Zeek (conn.log)
ZEEK_LOG_DIR=/var/log/zeek/current

# Interface réseau pour le fallback tcpdump
TCPDUMP_IFACE=eth0

# ─── Notifications ntfy ─────────────────────────────────────
# URL base du service ntfy auto-hébergé
NTFY_URL=http://ntfy:8080

# Topic ntfy (ne pas utiliser de topic public en production)
NTFY_TOPIC=log-analyzer-alerts

# Token d'authentification ntfy (optionnel si instance privée)
NTFY_TOKEN=

# Canaux de notification ordonnés par priorité
NOTIFIER_CHANNELS=ntfy,email

# Score minimal pour déclencher une notification (0.0–1.0)
ALERT_MIN_SCORE=0.6

# ─── Notifications email SMTP (fallback) ────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=alertes@example.com
SMTP_PASS=CHANGE_ME_smtp_password
SMTP_FROM=alertes@example.com
ALERT_EMAIL_TO=soc@example.com,responsable-si@example.com
SMTP_USE_TLS=true

# ─── SQLite checkpoint (ransomware analyst) ─────────────────
# Chemin de la base SQLite pour la persistance des analyses
SQLITE_DB_PATH=/app/data/analyses.db

# ─── Rétention et seuils ────────────────────────────────────
# Durée de rétention des archives (jours). Minimum ANSSI prod = 365.
LOG_RETENTION_DAYS=365

# Score de risque minimal pour escalade humaine (0.0–1.0)
ANOMALY_THRESHOLD=0.75
