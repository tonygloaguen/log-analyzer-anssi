# ============================================================
# .env.example — log-analyzer-anssi
# Copier vers .env.local et renseigner toutes les valeurs.
# NE JAMAIS committer .env.local dans le dépôt git.
# ============================================================

# ─── PostgreSQL ─────────────────────────────────────────────
# Identifiants de la base de données
POSTGRES_DB=log_analyzer
POSTGRES_USER=loguser
POSTGRES_PASSWORD=CHANGE_ME_strong_password_here

# DSN complet pour SQLAlchemy async (utilisé par le service api)
POSTGRES_DSN=postgresql+asyncpg://loguser:CHANGE_ME_strong_password_here@postgres:5432/log_analyzer

# ─── Intégrité HMAC — ANSSI ─────────────────────────────────
# Clé secrète HMAC-SHA256 pour la signature des archives de logs.
# Minimum 32 octets, encodage base64 recommandé.
# Générer avec : openssl rand -base64 48
HMAC_SECRET_KEY=CHANGE_ME_generate_with_openssl_rand_base64_48

# ─── Rétention et seuils ────────────────────────────────────
# Durée de rétention des archives (jours). Minimum ANSSI prod = 365.
LOG_RETENTION_DAYS=90

# Score de risque minimal pour escalade humaine (0.0–1.0)
ANOMALY_THRESHOLD=0.75

# ─── Ollama / LLM local ─────────────────────────────────────
# URL de l'instance Ollama (pas de cloud — conformité ANSSI)
OLLAMA_BASE_URL=http://ollama:11434

# Modèle principal pour classify_severity
OLLAMA_MODEL=mistral:7b-instruct

# Modèle pour le nœud ransomware_behavior_analyst
OLLAMA_RANSOMWARE_MODEL=granite3.3:8b

# ─── Loki ───────────────────────────────────────────────────
LOKI_URL=http://loki:3100

# ─── Grafana ────────────────────────────────────────────────
GRAFANA_USER=admin
GRAFANA_PASSWORD=CHANGE_ME_grafana_password

# ─── TLS (certificats mutuels — ANSSI) ──────────────────────
TLS_CERT_PATH=/certs/server.crt
TLS_KEY_PATH=/certs/server.key
TLS_CA_PATH=/certs/ca.crt

# ─── Collecteur réseau ──────────────────────────────────────
# Répertoire des logs Zeek (conn.log)
ZEEK_LOG_DIR=/var/log/zeek/current

# Interface réseau pour le fallback tcpdump
TCPDUMP_IFACE=eth0

# Intervalle de collecte réseau en secondes
NETWORK_POLL_INTERVAL_S=30

# ─── Détection BYOVD ────────────────────────────────────────
# Chemin du cache loldrivers.io (mis à jour par scripts/update_loldrivers.sh)
LOLDRIVERS_CACHE=data/loldrivers_cache.json

# URL source pour la mise à jour du cache loldrivers
LOLDRIVERS_URL=https://www.loldrivers.io/api/drivers.json

# Score minimal pour émettre une alerte BYOVD (0.0–1.0)
BYOVD_RISK_THRESHOLD=0.6

# ─── Notifications ──────────────────────────────────────────
# Score minimal pour déclencher une alerte (ntfy ou email)
ALERT_MIN_SCORE=0.6

# ntfy — canal push principal (auto-hébergeable)
# Exemple : https://ntfy.sh/mon-topic-prive ou http://ntfy:8080/alertes
NTFY_URL=https://ntfy.example.com/log-analyzer-alerts
NTFY_TOKEN=

# Email SMTP — fallback (obligatoire si sévérité CRITICAL)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=alertes@example.com
SMTP_PASSWORD=CHANGE_ME_smtp_password
SMTP_FROM=alertes@example.com
SMTP_TO=soc@example.com,responsable-si@example.com
SMTP_USE_TLS=true

# ─── Stockage logs ──────────────────────────────────────────
# Répertoire de base pour les archives de logs
# En production : monter sur partition physique dédiée
LOG_BASE_DIR=/var/log-analyzer
