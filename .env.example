# ─────────────────────────────────────────────────────────────────────────────
# .env.example — log-analyzer-anssi
#
# Copier ce fichier vers .env.local et renseigner les valeurs :
#   cp .env.example .env.local
#
# IMPORTANT : .env.local est gitignorés — ne jamais committer les secrets.
# En production : utiliser un gestionnaire de secrets (Vault, AWS Secrets Manager).
# ─────────────────────────────────────────────────────────────────────────────

# ── PostgreSQL ────────────────────────────────────────────────────────────────
# Mot de passe de la base de données (OBLIGATOIRE — erreur au démarrage si absent)
# Minimum 20 caractères recommandés en production
POSTGRES_PASSWORD=changeme-strong-password-here

# Nom de la base de données
POSTGRES_DB=log_analyzer

# Utilisateur PostgreSQL
POSTGRES_USER=loguser

# ── Sécurité / Intégrité ──────────────────────────────────────────────────────
# Clé HMAC-SHA256 pour la signature des archives de logs (OBLIGATOIRE)
# Minimum 32 bytes — générer avec : openssl rand -hex 32
# En production : stocker dans un HSM ou gestionnaire de secrets
HMAC_SECRET_KEY=changeme-generate-with-openssl-rand-hex-32

# ── Rétention des logs ────────────────────────────────────────────────────────
# Durée de rétention des logs archivés en jours
# ANSSI recommande 1 an minimum (365j) en production
# Défaut : 90j (adapté au développement et aux tests)
LOG_RETENTION_DAYS=90
# LOG_RETENTION_DAYS=365  # Valeur recommandée ANSSI en production

# ── LLM Local (Ollama) ────────────────────────────────────────────────────────
# URL du service Ollama — uniquement local (conformité ANSSI : pas de cloud)
OLLAMA_BASE_URL=http://ollama:11434

# ── Loki ──────────────────────────────────────────────────────────────────────
LOKI_URL=http://loki:3100

# ── Seuil d'anomalie ─────────────────────────────────────────────────────────
# Score de risque au-delà duquel une escalade humaine est déclenchée [0.0–1.0]
ANOMALY_THRESHOLD=0.75

# ── TLS ───────────────────────────────────────────────────────────────────────
# Chemins des certificats TLS (générés par ./scripts/gen_certs.sh)
# En production : certificats émis par une PKI d'entreprise
TLS_CERT_PATH=/certs/server.crt
TLS_KEY_PATH=/certs/server.key
TLS_CA_PATH=/certs/ca.crt

# ── Grafana ───────────────────────────────────────────────────────────────────
# Mot de passe administrateur Grafana (OBLIGATOIRE)
GRAFANA_PASSWORD=changeme-grafana-admin-password
GRAFANA_USER=admin

# ── API ───────────────────────────────────────────────────────────────────────
# Origines CORS autorisées (séparées par virgule)
# En production : restreindre à l'URL exacte du frontend
CORS_ORIGINS=http://localhost:3000

# ── Alertes (optionnel) ───────────────────────────────────────────────────────
# URL de webhook pour les notifications d'escalade (incidents graves)
# Laisser vide pour désactiver les notifications
# Formats supportés : Slack webhook, Teams webhook, URL HTTP POST générique
# ALERT_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz

# ── NTP ───────────────────────────────────────────────────────────────────────
NTP_SERVER=pool.ntp.org
